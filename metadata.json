{
  "name": "notes",
  "version": "1.0.0",
  "description": "Encrypted local-first notes for the Logos ecosystem",
  "type": "core",
  "main": "notes_plugin",
  "dependencies": [],
  "category": "notes",
  "icon": "",
  "nix": {
    "packages": { "build": ["libsodium", "pkg-config"], "runtime": ["libsodium"] },
    "external_libraries": [],
    "cmake": {
      "find_packages": ["Qt6 COMPONENTS Core Qml Sql", "PkgConfig REQUIRED"],
      "extra_sources": [
        "src/plugin/NotesPlugin.cpp",
        "src/core/NotesBackend.cpp",
        "src/core/CryptoManager.cpp",
        "src/core/DatabaseManager.cpp",
        "src/core/KeyManager.cpp",
        "src/core/StorageClient.cpp",
        "src/core/LogosStorageTransport.cpp"
      ],
      "extra_include_dirs": ["src"],
      "extra_link_libraries": ["Qt6::Sql", "PkgConfig::sodium", "dl", "pthread"]
    }
  }
